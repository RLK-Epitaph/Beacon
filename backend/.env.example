# ───────────────────────────────────────────────────────────────────
#  Beacon backend — environment config
#  Copy to ".env" and fill in. NEVER commit the real .env.
# ───────────────────────────────────────────────────────────────────

# Server
PORT=4000
# Where the React client runs (CORS + redirect target after OAuth)
CLIENT_ORIGIN=http://localhost:5173
# Where THIS backend is reachable (used to build OAuth redirect URIs)
SERVER_ORIGIN=http://localhost:4000
# Long random string — signs the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string
# AES-256 key (64 hex chars) used to encrypt stored tokens at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENC_KEY=replace-with-64-hex-characters

# ── Google ─────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth client (Web)
# Enable the Gmail API. Authorized redirect URI:
#   http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft ──────────────────────────────────────────────────────
# entra.microsoft.com → App registrations → New registration
# API permissions (delegated): Mail.ReadWrite, Mail.Send, offline_access, User.Read
# Redirect URI (Web):
#   http://localhost:4000/auth/microsoft/callback
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# "common" works for personal + work accounts; or use your tenant ID
MS_TENANT=common

# ── Slack ──────────────────────────────────────────────────────────
# api.slack.com/apps → your app → Basic Information.
# Redirect URL (OAuth & Permissions) must be HTTPS — use your ngrok tunnel:
#   https://YOUR-TUNNEL.ngrok-free.dev/auth/slack/callback
# and set SERVER_ORIGIN to the same tunnel origin so the backend builds
# matching redirect URIs.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Apple / iCloud ─────────────────────────────────────────────────
# Apple has no mail API. iCloud is reached over IMAP/SMTP using an
# APP-SPECIFIC PASSWORD the user generates at appleid.apple.com.
# Nothing to configure here — credentials are supplied per-account at connect time.
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
